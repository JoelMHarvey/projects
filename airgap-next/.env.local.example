# ── Clerk ──────────────────────────────────────────────────────────────────────
# Create account at https://clerk.com → New application → Next.js
# Copy keys from: Dashboard → API Keys

NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Where Clerk redirects after sign-in / sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

# ── Stripe ─────────────────────────────────────────────────────────────────────
# Create account at https://stripe.com → Developers → API Keys
# Create a monthly price at: Products → Add product → £8/month recurring
# Copy the Price ID (starts with price_...)

STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...           # set after creating webhook endpoint
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_PRICE_ID=price_...                 # your £8/month price ID

# ── App ────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://www.airgap.life   # or http://localhost:3000 locally
